# AutoYield Agent Configuration
# Copy this file to .env and customize as needed.

# Fernet encryption passphrase for the wallet key file.
# If empty, key is stored in plaintext (not recommended for production).
AUTOYIELD_PASSPHRASE=

# Solana RPC endpoint (Devnet only)
AUTOYIELD_RPC_URL=https://api.devnet.solana.com

# Path to the agent's key file
AUTOYIELD_WALLET_FILE=agent_state.key

# Minimum balance (in SOL) before auto-hydration kicks in
AUTOYIELD_MIN_BALANCE_SOL=0.5

# Amount (in SOL) to request per airdrop
AUTOYIELD_AIRDROP_SOL=2.0

# Default transfer amount (in SOL) for autonomous moves
AUTOYIELD_TRANSFER_SOL=0.1

# Optional: Import an existing agent private key (base58 string)
# If set, this overrides AUTOYIELD_WALLET_FILE.
AUTOYIELD_AGENT_KEY=
